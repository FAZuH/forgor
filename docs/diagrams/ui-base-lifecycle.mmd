sequenceDiagram
    autonumber
    participant R as Runner
    participant RT as Runtime
    participant AC as AppCore
    participant EH as EffectHandler
    participant V as View

    rect rgb(180, 200, 220)
        note right of R: INITIALIZATION
        R->>RT: new(core, effects)
        activate RT
        RT-->>R: runtime
        deactivate RT
        R->>V: new()
        activate V
        V-->>R: view
        deactivate V
    end

    rect rgb(180, 220, 190)
        note right of R: EVENT LOOP
        loop Until Quit
            opt On Tick
                R->>RT: dispatch(Msg::Tick)
            end

            opt Has Input
                R->>R: Map input to Msg
                R->>RT: dispatch(Msg)
            end

            opt Inside dispatch
                activate RT
                loop Until Msg queue is empty
                    RT->>AC: update(Msg)
                    activate AC
                    AC-->>RT: Vec~Cmd~
                    deactivate AC
                    
                    loop For each Cmd
                        RT->>EH: execute(Cmd)
                        activate EH
                        EH-->>RT: Vec~Msg~ (queue results)
                        deactivate EH
                    end
                end
                deactivate RT
            end

            opt Redraw
                R->>V: render(frame, core, settings_vs)
            end
        end
    end