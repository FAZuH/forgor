sequenceDiagram
    autonumber
    participant U as User
    participant R as TuiRunner
    participant TH as TickTimer
    participant RT as Runtime
    participant AC as AppCore
    participant EH as TuiEffectHandler
    participant V as TuiView
    participant S as External Services (Sound/Notify/DB)

    rect rgb(180, 200, 220)
        note right of R: INITIALIZATION
        R->>V: TuiView::new()
        R->>RT: Runtime::new(core, effect_handler)
        R->>R: TuiRunner::new(runtime, view)
    end

    rect rgb(180, 220, 190)
        note right of R: MAIN LOOP
        loop Until Quit
            R->>TH: new_tick()
            TH-->>R: tick_elapsed?

            opt On Tick
                R->>RT: dispatch(Msg::Tick)
            end

            opt Has Input
                U->>R: key event
                alt Page::Timer
                    R->>R: handle_timer(event)
                    R->>RT: dispatch(PomodoroMsg)
                else Page::Settings
                    R->>R: handle_settings(event)
                    R->>RT: dispatch(SettingsMsg)
                end
                R->>R: redraw = true
            end

            opt Inside Runtime dispatch
                activate RT
                loop Until Msg queue empty
                    RT->>AC: update(Msg)
                    activate AC
                    AC-->>RT: Vec~Cmd~
                    deactivate AC

                    loop For each Cmd
                        RT->>EH: execute(Cmd)
                        activate EH
                        
                        alt PlaySound / SaveConfig / RunHook
                            EH->>S: trigger side-effect
                        else ShowToast
                            EH->>EH: toast_handler.show()
                        end

                        EH-->>RT: Vec~Msg~ (queue results)
                        deactivate EH
                    end
                end
                deactivate RT
            end

            opt Redraw
                R->>V: render(frame, core, settings_vs)
                activate V
                V-->>R: rendered to frame
                deactivate V
                
                R->>EH: toast_mut().tick()
                R->>EH: toast_mut().render(frame)
                R->>R: terminal.draw()
            end
        end
    end